#!/bin/sh
set -eu

repository_root=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)

fail() {
    printf 'gradle gate failed: %s\n' "$1" >&2
    exit 1
}

"$repository_root/scripts/check-credentials"
"$repository_root/scripts/check-scope"

"$repository_root/backend/gradlew" -p "$repository_root/backend" \
    :shared-kernel:check \
    :features:identity:test \
    :features:identity:emulatorTest \
    :bootstrap:test \
    :bootstrap:emulatorTest \
    :architecture-tests:test \
    --console=plain

if ! command -v adb >/dev/null 2>&1; then
    fail "adb is required for Android instrumented tests"
fi

if ! adb devices | grep -Eq '^[^[:space:]]+[[:space:]]+device$'; then
    fail "Android emulator/device is required for connectedDevDebugAndroidTest"
fi

"$repository_root/mobile/gradlew" -p "$repository_root/mobile" \
    :core:common:allTests \
    :core:design-system:allTests \
    :compose-app:allTests \
    :android-app:testDevDebugUnitTest \
    :android-app:connectedDevDebugAndroidTest \
    --console=plain

discovered_tests=$(
    find "$repository_root/mobile" -type f -name '*.xml' \
        \( -path '*/test-results/*' -o -path '*/androidTest-results/*' \) \
        -exec cat {} + 2>/dev/null |
        grep -oE 'tests="[0-9]+"' |
        grep -oE '[0-9]+' |
        awk '{ sum += $1 } END { print sum + 0 }'
)

[ "$discovered_tests" -gt 0 ] 2>/dev/null ||
    fail "mobile suites reported BUILD SUCCESS with zero tests discovered"

printf 'ok - complete Kotlin and Android gate\n'
