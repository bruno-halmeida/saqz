#!/bin/sh
set -eu

repository_root=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)
child_pid=

if command -v /usr/libexec/java_home >/dev/null 2>&1; then
    java21=$(/usr/libexec/java_home -v 21 2>/dev/null || true)
    if [ -n "$java21" ]; then
        export JAVA_HOME=$java21
        export PATH="$JAVA_HOME/bin:$PATH"
    fi
fi

fail() {
    printf 'local gate failed: %s\n' "$1" >&2
    exit 1
}

cleanup() {
    status=$1
    if [ -n "${child_pid:-}" ] && kill -0 "$child_pid" 2>/dev/null; then
        kill "$child_pid" 2>/dev/null || true
        wait "$child_pid" 2>/dev/null || true
    fi
    exit "$status"
}

on_signal() {
    cleanup 130
}

trap on_signal INT TERM

run_step() {
    label=$1
    shift
    printf '==> %s\n' "$label"
    "$@" &
    child_pid=$!
    while kill -0 "$child_pid" 2>/dev/null; do
        sleep 0.1
    done
    if ! wait "$child_pid"; then
        child_pid=
        fail "$label"
    fi
    child_pid=
}

[ "$(uname -s)" = "Darwin" ] ||
    fail "scripts/check-all requires macOS for the iOS gate; run CI for supported platform coverage"

run_step 'Gradle/Kotlin/Android gate' "$repository_root/scripts/check-gradle"
run_step 'iOS gate' "$repository_root/scripts/check-ios"
run_step 'Landing gate' "$repository_root/scripts/check-landing"

printf 'ok - all local gates\n'
