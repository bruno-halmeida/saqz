#!/bin/bash
set -eu

repository_root=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)

fail() {
    printf 'credential gate failed: %s\n' "$1" >&2
    exit 1
}

tracked_files() {
    git -C "$repository_root" ls-files -z
}

tracked_files | while IFS= read -r -d '' file; do
    name=${file##*/}
    case "$name" in
        google-services.json|GoogleService-Info.plist)
            fail "forbidden Firebase platform file tracked: $file"
            ;;
        .env)
            fail "forbidden non-example environment file tracked: $file"
            ;;
        .env.*)
            case "$name" in
                *.example) ;;
                *) fail "forbidden non-example environment file tracked: $file" ;;
            esac
            ;;
    esac
done

scan_log=$(mktemp "${TMPDIR:-/tmp}/saqz-credentials.XXXXXX")
trap 'rm -f "$scan_log"' EXIT HUP INT TERM

if tracked_files | xargs -0 grep -InE -e \
    '-----BEGIN ([A-Z0-9]+ )?PRIVATE KEY-----|"type"[[:space:]]*:[[:space:]]*"service_account"|Authorization:[[:space:]]*Bearer[[:space:]]+[A-Za-z0-9._~+/=-]{20,}|Bearer[[:space:]]+eyJ[A-Za-z0-9._~+/=-]{20,}|AKIA[0-9A-Z]{16}' \
    >"$scan_log" 2>/dev/null; then
    if grep -q -- '-----BEGIN .*PRIVATE KEY-----' "$scan_log"; then
        cat "$scan_log" >&2
        fail "private-key literal found"
    fi
    if grep -q -- '"type"[[:space:]]*:[[:space:]]*"service_account"' "$scan_log"; then
        cat "$scan_log" >&2
        fail "service-account literal found"
    fi
    if grep -Eq -- 'Authorization:[[:space:]]*Bearer|Bearer[[:space:]]+eyJ' "$scan_log"; then
        cat "$scan_log" >&2
        fail "bearer-token literal found"
    fi
    if grep -q -- 'AKIA[0-9A-Z]\{16\}' "$scan_log"; then
        cat "$scan_log" >&2
        fail "credential literal found"
    fi
    cat "$scan_log" >&2
    fail "credential-like literal found"
fi

if command -v gitleaks >/dev/null 2>&1; then
    gitleaks_log=$(mktemp "${TMPDIR:-/tmp}/saqz-gitleaks.XXXXXX")
    set +e
    gitleaks detect --source "$repository_root" --redact --exit-code 97 >"$gitleaks_log" 2>&1
    status=$?
    set -e
    if [ "$status" -ne 0 ]; then
        cat "$gitleaks_log" >&2
        rm -f "$gitleaks_log"
        [ "$status" -eq 97 ] && fail "gitleaks classified a tracked secret"
        exit "$status"
    fi
    rm -f "$gitleaks_log"
fi

printf 'ok - credential safety\n'
