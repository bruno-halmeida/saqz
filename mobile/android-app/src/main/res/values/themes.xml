<resources>
    <!-- Post-splash theme the app content runs under; edge-to-edge is applied in code. -->
    <style name="Theme.Saqz.App" parent="android:Theme.Material.Light.NoActionBar" />

    <!-- API 23-30 launch screen via core-splashscreen back-compat attributes. -->
    <style name="Theme.Saqz.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/saqz_launch_background</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/saqz_launch_symbol</item>
        <item name="postSplashScreenTheme">@style/Theme.Saqz.App</item>
    </style>
</resources>
