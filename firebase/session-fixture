#!/bin/bash

set -euo pipefail
umask 077

repository_root=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)
state_dir=${SAQZ_FIXTURE_STATE_DIR:-$(mktemp -d "${TMPDIR:-/tmp}/saqz-session-fixture.XXXXXX")}
mkdir -p "$state_dir"
chmod 700 "$state_dir"
: >"$state_dir/pids"

project_id=saqz-local
emulator_pid=
account_email=
local_id=
cleaned=false

record_process_tree() {
    pid=$1
    printf '%s\n' "$pid" >>"$state_dir/pids"
    for child in $(pgrep -P "$pid" 2>/dev/null || true); do
        record_process_tree "$child"
    done
}

port_is_bindable() {
    python3 -c 'import socket; s=socket.socket(); s.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1); s.bind(("127.0.0.1", 9099)); s.close()' >/dev/null 2>&1
}

cleanup() {
    status=$?
    [ "$cleaned" = false ] || exit "$status"
    cleaned=true
    trap - EXIT INT TERM
    set +e

    if [ -n "$local_id" ] && [ -f "$state_dir/id-token" ]; then
        node -e 'const fs=require("fs"); process.stdout.write(JSON.stringify({idToken:fs.readFileSync(process.argv[1],"utf8").trim()}))' \
            "$state_dir/id-token" |
            curl -sS -o "$state_dir/delete-response" -H 'Content-Type: application/json' \
                -d @- "http://127.0.0.1:9099/identitytoolkit.googleapis.com/v1/accounts:delete?key=fake-saqz-local-api-key"
        node -e 'process.stdout.write(JSON.stringify({email:process.argv[1],password:"local-password-123",returnSecureToken:true}))' \
            "$account_email" |
            curl -sS -o "$state_dir/signin-after-delete" -H 'Content-Type: application/json' \
                -d @- "http://127.0.0.1:9099/identitytoolkit.googleapis.com/v1/accounts:signInWithPassword?key=fake-saqz-local-api-key"
        if node -e '
            const fs=require("fs");
            const body=JSON.parse(fs.readFileSync(process.argv[1],"utf8"));
            process.exit(body.error?.message === "EMAIL_NOT_FOUND" ? 0 : 1);
        ' "$state_dir/signin-after-delete"; then
            : >"$state_dir/account-deleted"
        else
            status=1
        fi
    fi
    rm -f "$state_dir/id-token" "$state_dir/signup-response" "$state_dir/delete-response"

    if [ -s "$state_dir/pids" ]; then
        while IFS= read -r pid; do
            kill -TERM "$pid" 2>/dev/null || true
        done <"$state_dir/pids"

        deadline=$((SECONDS + 5))
        while [ "$SECONDS" -lt "$deadline" ] && kill -0 "$emulator_pid" 2>/dev/null; do
            sleep 1
        done

        record_process_tree "$emulator_pid"
        sort -u "$state_dir/pids" -o "$state_dir/pids"
        while IFS= read -r pid; do
            kill -KILL "$pid" 2>/dev/null || true
        done <"$state_dir/pids"
        [ -z "$emulator_pid" ] || wait "$emulator_pid" 2>/dev/null || true
    fi

    deadline=$((SECONDS + 20))
    until port_is_bindable; do
        if [ "$SECONDS" -ge "$deadline" ]; then
            status=1
            break
        fi
        sleep 1
    done
    if port_is_bindable; then
        : >"$state_dir/port-bindable"
    fi
    exit "$status"
}

trap cleanup EXIT
trap 'exit 130' INT
trap 'exit 143' TERM

unset GOOGLE_APPLICATION_CREDENTIALS
npx --yes firebase-tools@15.23.0 emulators:start \
    --only auth \
    --project "$project_id" \
    --config "$repository_root/firebase.json" \
    >"$state_dir/emulator.log" 2>&1 &
emulator_pid=$!

deadline=$((SECONDS + 60))
until ! port_is_bindable; do
    if ! kill -0 "$emulator_pid" 2>/dev/null; then
        printf 'Firebase Auth Emulator exited before becoming ready\n' >&2
        exit 1
    fi
    if [ "$SECONDS" -ge "$deadline" ]; then
        printf 'Firebase Auth Emulator did not bind port 9099\n' >&2
        exit 1
    fi
    sleep 1
done

record_process_tree "$emulator_pid"
sort -u "$state_dir/pids" -o "$state_dir/pids"

account_email="session-$(uuidgen | tr '[:upper:]' '[:lower:]')@example.test"
node -e 'process.stdout.write(JSON.stringify({email:process.argv[1],password:"local-password-123",returnSecureToken:true}))' \
    "$account_email" |
    curl -sS -o "$state_dir/signup-response" -H 'Content-Type: application/json' \
        -d @- "http://127.0.0.1:9099/identitytoolkit.googleapis.com/v1/accounts:signUp?key=fake-saqz-local-api-key"

node -e '
    const fs=require("fs");
    const body=JSON.parse(fs.readFileSync(process.argv[1],"utf8"));
    if (!body.idToken || !body.localId || !body.email) process.exit(1);
    fs.writeFileSync(process.argv[2], body.idToken + "\n", {mode: 0o600});
    fs.writeFileSync(process.argv[3], body.localId + "\n", {mode: 0o600});
    fs.writeFileSync(process.argv[4], body.email + "\n", {mode: 0o600});
' "$state_dir/signup-response" "$state_dir/id-token" "$state_dir/subject" "$state_dir/email"

local_id=$(tr -d '\n' <"$state_dir/subject")

node -e '
    const fs=require("fs");
    process.stdout.write(JSON.stringify({
        idToken:fs.readFileSync(process.argv[1],"utf8").trim(),
        displayName:"Session Fixture",
        returnSecureToken:false
    }));
' "$state_dir/id-token" |
    curl -sS -o "$state_dir/update-response" -H 'Content-Type: application/json' \
        -d @- "http://127.0.0.1:9099/identitytoolkit.googleapis.com/v1/accounts:update?key=fake-saqz-local-api-key"

node -e '
    const fs=require("fs");
    process.stdout.write(JSON.stringify({
        requestType:"VERIFY_EMAIL",
        idToken:fs.readFileSync(process.argv[1],"utf8").trim()
    }));
' "$state_dir/id-token" |
    curl -sS -o "$state_dir/oob-request-response" -H 'Content-Type: application/json' \
        -d @- "http://127.0.0.1:9099/identitytoolkit.googleapis.com/v1/accounts:sendOobCode?key=fake-saqz-local-api-key"

curl -sS -o "$state_dir/oob-codes" \
    "http://127.0.0.1:9099/emulator/v1/projects/$project_id/oobCodes"

node -e '
    const fs=require("fs");
    const body=JSON.parse(fs.readFileSync(process.argv[1],"utf8"));
    const email=process.argv[3];
    const match=(body.oobCodes || []).find(code => code.email === email && code.requestType === "VERIFY_EMAIL");
    if (!match) {
        console.error(JSON.stringify(body));
        process.exit(1);
    }
    fs.writeFileSync(process.argv[2], match.oobCode + "\n", {mode: 0o600});
' "$state_dir/oob-codes" "$state_dir/oob-code" "$account_email"

node -e '
    const fs=require("fs");
    process.stdout.write(JSON.stringify({oobCode:fs.readFileSync(process.argv[1],"utf8").trim()}));
' "$state_dir/oob-code" |
    curl -sS -o "$state_dir/verify-response" -H 'Content-Type: application/json' \
        -d @- "http://127.0.0.1:9099/identitytoolkit.googleapis.com/v1/accounts:update?key=fake-saqz-local-api-key"

node -e 'process.stdout.write(JSON.stringify({email:process.argv[1],password:"local-password-123",returnSecureToken:true}))' \
    "$account_email" |
    curl -sS -o "$state_dir/signin-response" -H 'Content-Type: application/json' \
        -d @- "http://127.0.0.1:9099/identitytoolkit.googleapis.com/v1/accounts:signInWithPassword?key=fake-saqz-local-api-key"

node -e '
    const fs=require("fs");
    const body=JSON.parse(fs.readFileSync(process.argv[1],"utf8"));
    if (!body.idToken || body.registered !== true) {
        console.error(JSON.stringify(body));
        process.exit(1);
    }
    fs.writeFileSync(process.argv[2], body.idToken + "\n", {mode: 0o600});
' "$state_dir/signin-response" "$state_dir/id-token"

: >"$state_dir/ready"

if [ "${SAQZ_FIXTURE_FAIL:-false}" = true ]; then
    exit 1
fi

if [ "${SAQZ_FIXTURE_HOLD:-false}" = true ]; then
    while true; do sleep 1; done
fi
