meta {
  name: List Memberships
  type: http
  seq: 7
}

get {
  url: {{backendUrl}}/api/groups/{{groupId}}/memberships
  body: none
  auth: none
}

headers {
  Authorization: Bearer {{idToken}}
}

tests {
  test("memberships are returned without secrets", function () {
    expect(res.getStatus()).to.equal(200);
    expect(res.getBody()).to.be.an("array");
    expect(JSON.stringify(res.getBody())).not.to.contain("password");
  });
}
