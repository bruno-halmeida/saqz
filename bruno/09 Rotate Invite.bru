meta {
  name: Rotate Invite
  type: http
  seq: 9
}

post {
  url: {{backendUrl}}/api/groups/{{groupId}}/invite
  body: none
  auth: none
}

headers {
  Authorization: Bearer {{idToken}}
}

tests {
  test("invite returns opaque URL", function () {
    expect(res.getStatus()).to.equal(200);
    expect(res.getBody().inviteUrl).to.be.a("string").and.not.empty;
    expect(res.getBody()).not.to.have.property("code");
  });
}
