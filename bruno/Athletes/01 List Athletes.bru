meta {
  name: List Athletes
  type: http
  seq: 1
}

get {
  url: {{backendUrl}}/api/groups/{{groupId}}/athletes?search=&type=&position=&financialStatus=&includeInactive=false
  body: none
  auth: none
}

headers {
  Authorization: Bearer {{idToken}}
}

tests {
  test("roster is returned for organizers", function () {
    expect(res.getStatus()).to.equal(200);
    expect(res.getBody().athletes).to.be.an("array");
  });
}
