meta {
  name: Read Game
  type: http
  seq: 3
}
get {
  url: {{baseUrl}}/api/groups/{{groupId}}/games/{{gameId}}
  body: none
  auth: bearer
}
auth:bearer {
  token: {{idToken}}
}
tests {
  test("game with ETag", function () { expect(res.status).to.equal(200); expect(res.headers.etag).to.exist; expect(res.body.confirmedCount).to.be.a("number"); expect(res.body).to.have.property("ownAttendance"); });
}
