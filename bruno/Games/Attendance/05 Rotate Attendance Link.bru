meta {
  name: Rotate Attendance Link
  type: http
  seq: 5
}

post {
  url: {{backendUrl}}/api/groups/{{groupId}}/games/{{gameId}}/attendance-link
  body: none
  auth: none
}

headers {
  Authorization: Bearer {{idToken}}
}

tests {
  test("attendance link returns opaque URL", function () {
    expect(res.getStatus()).to.equal(200);
    expect(res.getBody().url).to.be.a("string").and.not.empty;
    expect(res.getBody()).not.to.have.property("code");
  });
}
