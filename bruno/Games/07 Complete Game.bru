meta {
  name: Complete Game
  type: http
  seq: 7
}
post {
  url: {{baseUrl}}/api/groups/{{groupId}}/games/{{gameId}}/complete
  body: none
  auth: bearer
}
headers {
  If-Match: {{gameEtag}}
}
auth:bearer {
  token: {{idToken}}
}
tests {
  test("completed", function () { expect(res.status).to.equal(200); expect(res.body.status).to.equal("COMPLETED"); });
}
