meta {
  name: My Charges
  type: http
  seq: 2
}
get {
  url: {{baseUrl}}/api/groups/{{groupId}}/charges/me
  body: none
  auth: bearer
}
auth:bearer { token: {{idToken}} }
tests {
  test("own charges are redacted", function () { expect(res.status).to.equal(200); expect(res.body.charges).to.be.an("array"); expect(res.body.pendingTotalCents).to.equal(null); });
}
