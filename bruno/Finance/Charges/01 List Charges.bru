meta {
  name: List Charges
  type: http
  seq: 1
}
get {
  url: {{baseUrl}}/api/groups/{{groupId}}/charges
  body: none
  auth: bearer
}
auth:bearer { token: {{idToken}} }
tests {
  test("manual organizer charges", function () { expect(res.status).to.equal(200); expect(res.body.charges).to.be.an("array"); expect(res.body).not.to.have.property("settledTotalCents"); });
}
